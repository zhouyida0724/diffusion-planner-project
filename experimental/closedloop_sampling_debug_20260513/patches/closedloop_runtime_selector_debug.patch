+            root_to_label[root] = len(root_to_label)
+        mode_labels.append(root_to_label[root])
+    mode_counts = np.bincount(np.asarray(mode_labels, dtype=np.int64), minlength=len(root_to_label)).astype(np.float64)
+    mode_probs = mode_counts / float(max(1, num_candidates))
+    mode_entropy = float(-np.sum(mode_probs * np.log(np.maximum(mode_probs, 1e-12))))
+
+    trajectory_spread = float(np.mean(finite_rms)) if len(finite_rms) else 0.0
+    endpoint_spread = float(np.mean(finite_final)) if len(finite_final) else 0.0
+
+    return {
+        "num_candidates": int(num_candidates),
+        "pairwise_rms_min_m": float(np.min(finite_rms)) if len(finite_rms) else 0.0,
+        "pairwise_rms_mean_m": trajectory_spread,
+        "pairwise_rms_max_m": float(np.max(finite_rms)) if len(finite_rms) else 0.0,
+        "trajectory_spread": trajectory_spread,
+        "pairwise_final_l2_min_m": float(np.min(finite_final)) if len(finite_final) else 0.0,
+        "pairwise_final_l2_mean_m": endpoint_spread,
+        "pairwise_final_l2_max_m": float(np.max(finite_final)) if len(finite_final) else 0.0,
+        "endpoint_spread": endpoint_spread,
+        "per_candidate_nn_rms_xy_m": per_candidate_nn_rms,
+        "per_candidate_mean_rms_xy_m": per_candidate_mean_rms,
+        "per_candidate_nn_final_l2_m": per_candidate_nn_final,
+        "per_candidate_mean_final_l2_m": per_candidate_mean_final,
+        "effective_modes": int(len(root_to_label)),
+        "mode_entropy": mode_entropy,
+        "candidate_mode_labels": mode_labels,
+        "mode_rms_threshold_m": mode_rms_threshold_m,
+        "mode_final_l2_threshold_m": mode_final_l2_threshold_m,
+    }
+
+
+def route_feature_sanity(route_lanes: np.ndarray | None, route_lanes_avails: np.ndarray | None) -> dict[str, object]:
+    if route_lanes is None or route_lanes_avails is None:
+        return {
+            "route_lane_count": 0,
+            "route_avail_points": 0,
+            "route_points_finite": True,
+            "route_first_point_norm_m": math.inf,
+            "route_last_point_norm_m": math.inf,
+            "route_local_min_xy": np.zeros((2,), dtype=np.float64),
+            "route_local_max_xy": np.zeros((2,), dtype=np.float64),
+        }
+    lanes = np.asarray(route_lanes, dtype=np.float64)
+    avails = np.asarray(route_lanes_avails)
+    if lanes.ndim < 3 or lanes.shape[-1] < 2 or avails.ndim < 2:
+        return {
+            "route_lane_count": 0,
+            "route_avail_points": 0,
+            "route_points_finite": False,
+            "route_first_point_norm_m": math.inf,
+            "route_last_point_norm_m": math.inf,
+            "route_local_min_xy": np.zeros((2,), dtype=np.float64),
+            "route_local_max_xy": np.zeros((2,), dtype=np.float64),
+        }
+
+    valid_mask = avails > 0
+    lane_valid_mask = np.any(valid_mask, axis=1)
+    points = lanes[:, :, :2][valid_mask]
+    if len(points) == 0:
+        return {
+            "route_lane_count": int(np.count_nonzero(lane_valid_mask)),
+            "route_avail_points": 0,
+            "route_points_finite": True,
+            "route_first_point_norm_m": math.inf,
+            "route_last_point_norm_m": math.inf,
+            "route_local_min_xy": np.zeros((2,), dtype=np.float64),
+            "route_local_max_xy": np.zeros((2,), dtype=np.float64),
+        }
+
+    return {
+        "route_lane_count": int(np.count_nonzero(lane_valid_mask)),
+        "route_avail_points": int(np.count_nonzero(valid_mask)),
+        "route_points_finite": bool(np.all(np.isfinite(points))),
+        "route_first_point_norm_m": float(np.linalg.norm(points[0])),
+        "route_last_point_norm_m": float(np.linalg.norm(points[-1])),
+        "route_local_min_xy": np.min(points, axis=0),
+        "route_local_max_xy": np.max(points, axis=0),
+    }
+
+
+def candidate_route_projection_summaries(candidates_local_xyh: list[np.ndarray], route_centerlines_local: list[np.ndarray]) -> dict[str, object]:
+    candidates = [np.asarray(candidate, dtype=np.float64) for candidate in candidates_local_xyh]
+    num_candidates = len(candidates)
+    min_lateral = np.full((num_candidates,), np.inf, dtype=np.float64)
+    final_lateral = np.full((num_candidates,), np.inf, dtype=np.float64)
+    max_lateral = np.full((num_candidates,), np.inf, dtype=np.float64)
+    final_progress = np.zeros((num_candidates,), dtype=np.float64)
+    remaining_to_end = np.full((num_candidates,), np.inf, dtype=np.float64)
+    beyond_end = np.zeros((num_candidates,), dtype=bool)
+    projection_finite = np.zeros((num_candidates,), dtype=bool)
+
+    route_points, route_progress = _flatten_route(route_centerlines_local)
+    route_end_progress = float(route_progress[-1]) if len(route_progress) else 0.0
+    route_end_point = route_points[-1] if len(route_points) else None
+    route_end_tangent = np.zeros((2,), dtype=np.float64)
+    if len(route_points) >= 2:
+        route_end_tangent = route_points[-1] - route_points[-2]
+        norm = float(np.linalg.norm(route_end_tangent))
+        if norm > 1e-6:
+            route_end_tangent = route_end_tangent / norm
+
+    for candidate_index, candidate in enumerate(candidates):
+        if len(candidate) == 0:
+            continue
+        nearest_dist, candidate_progress, _ = project_to_route(candidate[:, :2], route_centerlines_local)
+        finite_mask = np.isfinite(nearest_dist)
+        projection_finite[candidate_index] = bool(np.all(finite_mask) and len(nearest_dist) > 0)
+        if len(nearest_dist) == 0 or not np.any(finite_mask):
+            continue
+        finite_dist = nearest_dist[finite_mask]
+        min_lateral[candidate_index] = float(np.min(finite_dist))
+        max_lateral[candidate_index] = float(np.max(finite_dist))
+        final_lateral[candidate_index] = float(nearest_dist[-1])
+        final_progress[candidate_index] = float(candidate_progress[-1]) if len(candidate_progress) else 0.0
+        remaining_to_end[candidate_index] = max(0.0, route_end_progress - final_progress[candidate_index])
+        if route_end_point is not None and np.any(route_end_tangent):
+            beyond_amount = float(np.dot(candidate[-1, :2] - route_end_point, route_end_tangent))
+            beyond_end[candidate_index] = bool(beyond_amount > 0.5 and final_progress[candidate_index] >= route_end_progress - 1e-6)
+
+    return {
+        "num_candidates": int(num_candidates),
+        "min_lateral_error_m": min_lateral,
+        "final_lateral_error_m": final_lateral,
+        "max_lateral_error_m": max_lateral,
+        "final_progress_m": final_progress,
+        "remaining_to_route_end_m": remaining_to_end,
+        "beyond_route_end": beyond_end,
+        "projection_finite": projection_finite,
+    }
+
+
+def candidate_obstacle_proxies(candidates_local_xyh: list[np.ndarray], context: SelectionContext) -> dict[str, object]:
+    candidates = [np.asarray(candidate, dtype=np.float64) for candidate in candidates_local_xyh]
+    num_candidates = len(candidates)
+    min_dynamic_clearance = np.full((num_candidates,), math.inf, dtype=np.float64)
+    min_static_clearance = np.full((num_candidates,), math.inf, dtype=np.float64)
+    min_clearance_step = np.full((num_candidates,), -1, dtype=np.int64)
+    has_negative_clearance = np.zeros((num_candidates,), dtype=bool)
+    proxy_collision = np.zeros((num_candidates,), dtype=bool)
+    proxy_first_collision_step = np.full((num_candidates,), -1, dtype=np.int64)
+    proxy_ttc_s = np.full((num_candidates,), math.inf, dtype=np.float64)
+    min_ttc_clearance = np.full((num_candidates,), math.inf, dtype=np.float64)
+
+    ego_radius = float(math.hypot(float(context.vehicle_half_length), float(context.vehicle_half_width)))
+    dynamic_xy, dynamic_velocity, dynamic_radius = _dynamic_obstacle_state(getattr(context, "neighbor_agents_past", None))
+    static_xy, static_radius = _static_obstacle_state(getattr(context, "static_objects", None))
+
+    for candidate_index, candidate in enumerate(candidates):
+        if len(candidate) == 0:
+            continue
+        candidate_xy = candidate[:, :2]
+        clearance_series: list[np.ndarray] = []
+        if len(dynamic_xy):
+            times = np.arange(len(candidate_xy), dtype=np.float64) * float(context.dt)
+            obstacle_xy = dynamic_xy[None, :, :] + times[:, None, None] * dynamic_velocity[None, :, :]
+            distances = np.linalg.norm(candidate_xy[:, None, :] - obstacle_xy, axis=-1)
+            dynamic_clearance = distances - ego_radius - dynamic_radius[None, :]
+            clearance_series.append(dynamic_clearance)
+            min_dynamic_clearance[candidate_index] = float(np.min(dynamic_clearance))
+        if len(static_xy):
+            distances = np.linalg.norm(candidate_xy[:, None, :] - static_xy[None, :, :], axis=-1)
+            static_clearance = distances - ego_radius - static_radius[None, :]
+            clearance_series.append(static_clearance)
+            min_static_clearance[candidate_index] = float(np.min(static_clearance))
+        if not clearance_series:
+            continue
+        all_clearance = np.concatenate(clearance_series, axis=1)
+        per_step_min = np.min(all_clearance, axis=1)
+        min_step = int(np.argmin(per_step_min))
+        min_clearance_step[candidate_index] = min_step
+        min_ttc_clearance[candidate_index] = float(per_step_min[min_step])
+        has_negative_clearance[candidate_index] = bool(np.any(per_step_min < 0.0))
+        proxy_collision[candidate_index] = bool(has_negative_clearance[candidate_index])
+        if proxy_collision[candidate_index]:
+            first_collision = int(np.argmax(per_step_min < 0.0))
+            proxy_first_collision_step[candidate_index] = first_collision
+            proxy_ttc_s[candidate_index] = float(first_collision) * float(context.dt)
+
+    return {
+        "num_candidates": int(num_candidates),
+        "dynamic_agent_count": int(len(dynamic_xy)),
+        "static_object_count": int(len(static_xy)),
+        "min_dynamic_clearance_m": min_dynamic_clearance,
+        "min_static_clearance_m": min_static_clearance,
+        "min_clearance_step": min_clearance_step,
+        "has_negative_clearance": has_negative_clearance,
+        "proxy_collision": proxy_collision,
+        "proxy_first_collision_step": proxy_first_collision_step,
+        "proxy_ttc_s": proxy_ttc_s,
+        "min_ttc_clearance_m": min_ttc_clearance,
+    }
+
+
+def _dynamic_obstacle_state(neighbor_agents_past: np.ndarray | None) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
+    if neighbor_agents_past is None:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    agents = np.asarray(neighbor_agents_past, dtype=np.float64)
+    if agents.ndim != 3 or agents.shape[0] <= 1 or agents.shape[2] < 11:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    current = agents[1:, -1, :]
+    valid = current[:, 10] > 0.5
+    current = current[valid]
+    if len(current) == 0:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    obstacle_xy = current[:, :2]
+    obstacle_velocity = current[:, 4:6]
+    widths = np.maximum(current[:, 8], 0.1)
+    lengths = np.maximum(current[:, 9], 0.1)
+    obstacle_radius = 0.5 * np.sqrt(widths * widths + lengths * lengths)
+    return obstacle_xy, obstacle_velocity, obstacle_radius
+
+
+def _static_obstacle_state(static_objects: np.ndarray | None) -> tuple[np.ndarray, np.ndarray]:
+    if static_objects is None:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    objects = np.asarray(static_objects, dtype=np.float64)
+    if objects.ndim != 2 or objects.shape[1] < 10:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    valid = objects[:, 9] > 0.5
+    objects = objects[valid]
+    if len(objects) == 0:
+        return np.zeros((0, 2), dtype=np.float64), np.zeros((0,), dtype=np.float64)
+    object_xy = objects[:, :2]
+    widths = np.maximum(objects[:, 3], 0.1)
+    lengths = np.maximum(objects[:, 4], 0.1)
+    object_radius = 0.5 * np.sqrt(widths * widths + lengths * lengths)
+    return object_xy, object_radius
